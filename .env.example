# ============================================================
# 環境変数サンプル（コピーして .env.local / .env.development / .env.production で使用）
# 本番と開発で Supabase プロジェクトを分ける場合、URL と KEY を差し替える
# ============================================================

# Supabase（開発用プロジェクト）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 外部API（環境ごとに test/live や sandbox を切り替える）
# GEMINI_API_KEY=...
# NEXT_PUBLIC_CONTACT_FORM_URL=...
