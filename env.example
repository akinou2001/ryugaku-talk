# ============================================
# 環境変数設定ガイド
# ============================================
# このファイルは環境変数のテンプレートです。
# 実際の値は .env.local ファイルに設定してください（開発環境用）
# 本番環境では、Vercelの環境変数設定を使用します。
#
# 環境分離について:
# - 開発環境: .env.local ファイルを使用（ローカル開発用）
# - 本番環境: Vercelダッシュボードの環境変数設定を使用
# - 各環境で異なるSupabaseプロジェクトを使用することを推奨
# ============================================

# ============================================
# Supabase Configuration
# ============================================
# 【開発環境】開発用Supabaseプロジェクトの認証情報を設定
# 【本番環境】VercelのProduction環境変数に本番用Supabaseプロジェクトの認証情報を設定
# 
# 重要: 開発環境と本番環境で異なるSupabaseプロジェクトを使用してください
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# App URL Configuration
# ============================================
# 【開発環境】http://localhost:3000
# 【本番環境】https://ryugakutalk.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Site Configuration
# ============================================
# 【開発環境】http://localhost:3000 または開発用URL
# 【本番環境】https://ryugakutalk.com
NEXT_PUBLIC_SITE_URL=https://ryugakutalk.com

# 【開発環境】localhost または開発用ドメイン
# 【本番環境】ryugakutalk.com
NEXT_PUBLIC_SITE_DOMAIN=ryugakutalk.com

# 連絡先メールアドレス（環境共通）
NEXT_PUBLIC_CONTACT_EMAIL=contact@ryugakutalk.com

# ============================================
# Next.js Configuration
# ============================================
# 【開発環境】http://localhost:3000
# 【本番環境】https://ryugakutalk.com
NEXTAUTH_URL=http://localhost:3000

# NextAuthのシークレットキー（環境ごとに異なる値を推奨）
NEXTAUTH_SECRET=your_nextauth_secret

# ============================================
# API Keys Configuration
# ============================================
# これらのAPIキーは環境ごとに設定できます
# 開発環境では開発用のキー、本番環境では本番用のキーを使用することを推奨

# OpenAI API Configuration (for AI Concierge)
# 【開発環境】開発用APIキー（使用量制限を設定することを推奨）
# 【本番環境】本番用APIキー
OPENAI_API_KEY=your_openai_api_key

# DashScope API Configuration (for AI Search - route2.ts)
# 【開発環境】開発用APIキー
# 【本番環境】本番用APIキー
DASHSCOPE_API_KEY=your_dashscope_api_key

# ============================================
# Customer Support / Contact Form
# ============================================
# GoogleフォームのURLを設定してください
# 例: https://docs.google.com/forms/d/e/1FAIpQLSd.../viewform
# 環境ごとに異なるフォームを使用することも可能


